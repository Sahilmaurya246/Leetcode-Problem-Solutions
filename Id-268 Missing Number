class Solution {
public:
    int missingNumber(vector<int>& nums) {
        int n = nums.size();
        int expected = n * (n + 1) / 2;
        
        int missnumber = 0;
        for(int i = 0; i < nums.size(); i++) {
            missnumber += nums[i];
        }

        return expected - missnumber;
    }
};
